<?xml version="1.0" encoding="utf-8"?>
<robot name="unitree_h1_gazebo_light">
  <link name="world"/>

  <link name="pelvis">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.28 0.18 0.18"/></geometry>
      <material name="Gray"><color rgba="0.7 0.7 0.7 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.28 0.18 0.18"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="12.0"/>
      <inertia ixx="0.10" ixy="0" ixz="0" iyy="0.10" iyz="0" izz="0.10"/>
    </inertial>
  </link>
  <joint name="floating_base_joint" type="fixed">
    <parent link="world"/>
    <child link="pelvis"/>
    <origin xyz="0 0 1.0" rpy="0 0 0"/>
  </joint>

  <link name="torso_link">
    <visual><geometry><box size="0.24 0.16 0.30"/></geometry></visual>
    <collision><geometry><box size="0.24 0.16 0.30"/></geometry></collision>
    <inertial><mass value="8.0"/><inertia ixx="0.06" ixy="0" ixz="0" iyy="0.06" iyz="0" izz="0.06"/></inertial>
  </link>
  <joint name="torso_joint" type="fixed">
    <parent link="pelvis"/>
    <child link="torso_link"/>
    <origin xyz="0 0 0.24" rpy="0 0 0"/>
  </joint>

  <link name="left_upper_arm">
    <visual><origin xyz="0 0 -0.12" rpy="0 0 0"/><geometry><cylinder radius="0.03" length="0.24"/></geometry></visual>
    <collision><origin xyz="0 0 -0.12" rpy="0 0 0"/><geometry><cylinder radius="0.03" length="0.24"/></geometry></collision>
    <inertial><mass value="1.5"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="left_shoulder_pitch_joint" type="fixed">
    <parent link="torso_link"/>
    <child link="left_upper_arm"/>
    <origin xyz="0 0.14 0.18" rpy="0 0 0"/>
  </joint>

  <link name="left_forearm">
    <visual><origin xyz="0 0 -0.11" rpy="0 0 0"/><geometry><cylinder radius="0.022" length="0.22"/></geometry></visual>
    <collision><origin xyz="0 0 -0.11" rpy="0 0 0"/><geometry><cylinder radius="0.022" length="0.22"/></geometry></collision>
    <inertial><mass value="1.0"/><inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.006"/></inertial>
  </link>
  <joint name="left_elbow_joint" type="fixed">
    <parent link="left_upper_arm"/>
    <child link="left_forearm"/>
    <origin xyz="0 0 -0.24" rpy="0 0 0"/>
  </joint>

  <link name="right_upper_arm">
    <visual><origin xyz="0 0 -0.12" rpy="0 0 0"/><geometry><cylinder radius="0.03" length="0.24"/></geometry></visual>
    <collision><origin xyz="0 0 -0.12" rpy="0 0 0"/><geometry><cylinder radius="0.03" length="0.24"/></geometry></collision>
    <inertial><mass value="1.5"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="right_shoulder_pitch_joint" type="fixed">
    <parent link="torso_link"/>
    <child link="right_upper_arm"/>
    <origin xyz="0 -0.14 0.18" rpy="0 0 0"/>
  </joint>

  <link name="right_forearm">
    <visual><origin xyz="0 0 -0.11" rpy="0 0 0"/><geometry><cylinder radius="0.022" length="0.22"/></geometry></visual>
    <collision><origin xyz="0 0 -0.11" rpy="0 0 0"/><geometry><cylinder radius="0.022" length="0.22"/></geometry></collision>
    <inertial><mass value="1.0"/><inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.006"/></inertial>
  </link>
  <joint name="right_elbow_joint" type="fixed">
    <parent link="right_upper_arm"/>
    <child link="right_forearm"/>
    <origin xyz="0 0 -0.24" rpy="0 0 0"/>
  </joint>
</robot>
